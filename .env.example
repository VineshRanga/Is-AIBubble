# Copy to .env and fill in values. Never commit .env.

# SEC EDGAR requires a descriptive User-Agent header (name + email).
# Format: "YourName YourEmail@domain.com"
SEC_EDGAR_USER_AGENT="YourName your.email@domain.com"

# Optional: override project root for non-standard layouts
# PROJECT_ROOT=/path/to/Is-AIBubble
